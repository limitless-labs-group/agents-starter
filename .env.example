# Required
PRIVATE_KEY=0x...your-wallet-private-key
LIMITLESS_API_KEY=lmts_...your-api-key

# Safety
DRY_RUN=true
MAX_TOTAL_EXPOSURE_USD=50
MAX_SINGLE_TRADE_USD=10

# Optional
COINGECKO_API_KEY=CG-...optional-for-signal-strategy
LOG_LEVEL=info

# Oracle Arb Strategy (optional - uses defaults if not set)
# ORACLE_ASSETS=BTC,ETH,SOL
# ORACLE_MIN_CONFIDENCE=0.75
# ORACLE_MIN_EDGE=0.15
# ORACLE_MAX_PRICE=0.70
# ORACLE_BET_SIZE=2
# ORACLE_MAX_POSITIONS=10
# ORACLE_MIN_MINUTES=0
# ORACLE_MAX_MINUTES=90
