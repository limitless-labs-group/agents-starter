# ═════════════════════════════════════════════════════════════
# REQUIRED — every strategy needs these
# ═════════════════════════════════════════════════════════════

# Wallet private key. Signs orders on Limitless (Base). For the cross-market-mm
# strategy, ALSO signs on Polymarket (Polygon) — same EOA, two chains.
# Use a dedicated trading wallet, never your main wallet.
PRIVATE_KEY=0x...your-wallet-private-key

# ── Limitless auth — scoped HMAC token ───────────────────────────
# Limitless authenticates API requests with scoped tokens (HMAC-SHA256).
# Get yours from the UI (takes ~20 seconds, one time):
#   1. limitless.exchange → Connect your wallet
#   2. Open the API token modal → "API Tokens" tab → Derive
#   3. Copy the tokenId + secret into the two lines below
# The browser handles the login session for you — you never touch a Privy
# token, and no smart wallet is involved. The SDK signs every request with
# these (lmts-api-key / lmts-timestamp / lmts-signature) automatically.
LMTS_TOKEN_ID=your-token-id
LMTS_TOKEN_SECRET=your-base64-token-secret
#
# Headless / CI (can't open a browser)? Derive programmatically instead:
#   npm run derive-token   — see src/core/limitless/derive-token.ts header.
#
# Legacy: an older X-API-Key still works if you already hold one — set
# LIMITLESS_API_KEY and leave LMTS_TOKEN_* blank. New setups: use the token above.
# LIMITLESS_API_KEY=your-legacy-api-key

# ── Polymarket deposit-wallet setup (cross-market-mm hedge side) ──────
# Polymarket's CLOB rejects orders from a Gnosis Safe ("use the deposit wallet
# flow"). New API users trade via a POLY_1271 deposit wallet (sig type 3).
# Create a relayer API key in the Polymarket builder dashboard, then run
#   npm run cross-market-mm:setup-poly
# to derive + deploy your deposit wallet and approve pUSD (gasless). It prints
# the deposit-wallet address to set as poly_funder (with poly_signature_type: 3).
# RELAYER_API_KEY=your-relayer-api-key
# RELAYER_API_KEY_ADDRESS=0xyour-signer-eoa-address

# ═════════════════════════════════════════════════════════════
# SAFETY — set DRY_RUN=true for your first runs
# ═════════════════════════════════════════════════════════════

# true: every order intent is logged, nothing is signed or submitted.
# false: real orders, real money.
DRY_RUN=true

# ═════════════════════════════════════════════════════════════
# GENERAL
# ═════════════════════════════════════════════════════════════

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Where strategies persist learning files + position state. Default: ./data
# DATA_DIR=./data

# ═════════════════════════════════════════════════════════════
# URL OVERRIDES — defaults work; override only for staging / custom envs
# ═════════════════════════════════════════════════════════════

# Limitless
# LIMITLESS_API_URL=https://api.limitless.exchange
# LIMITLESS_WS_URL=wss://ws.limitless.exchange

# Polymarket (cross-market-mm only)
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_DATA_URL=https://data-api.polymarket.com
# POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ═════════════════════════════════════════════════════════════
# PER-STRATEGY TUNABLES — all optional, defaults shown
# ═════════════════════════════════════════════════════════════

# ─── oracle-arb ────────────────────────────────────────────────
# Hermes/Pyth oracle vs market price arbitrage.
# `npm run oracle-arb`
# ORACLE_ASSETS=BTC,ETH,SOL                # Pyth tickers
# ORACLE_MIN_CONFIDENCE=0.82               # min oracle confidence (0..1)
# ORACLE_MIN_EDGE=0.20                     # min edge oracle vs market (0..1)
# ORACLE_MIN_PRICE=0.30                    # market-price floor; skip below
# ORACLE_MAX_PRICE=0.65                    # market-price ceiling; skip above
# ORACLE_BET_SIZE=1                        # USD per trade
# ORACLE_MAX_POSITIONS=10                  # max concurrent open positions
# ORACLE_MIN_MINUTES=0                     # min minutes to expiry
# ORACLE_MAX_MINUTES=90                    # max minutes to expiry

# ─── certainty-closer ──────────────────────────────────────────
# SDK-only example: buys the near-resolution favourite, sized via fractional
# Kelly (core/kelly.ts). No external feeds. On its own it has no independent
# edge — the edge is CC_ASSUMED_EDGE, which YOU assert. `npm run certainty-closer`
# CC_MIN_LEAD=0.85                         # min price on the leading side (0..1)
# CC_MAX_LEAD=0.97                         # max price (above this the return is too thin)
# CC_MIN_MINUTES=0                         # min minutes to expiry
# CC_MAX_MINUTES=30                        # max minutes to expiry
# CC_ASSUMED_EDGE=0.03                     # YOUR edge over the market (0 = won't bet)
# CC_BANKROLL=50                           # bankroll the Kelly sizer sizes against (USD)
# CC_KELLY_FRACTION=0.25                   # Kelly multiplier (0.25 = quarter-Kelly)
# CC_MAX_RISK=2                            # hard cap on $ risked per bet
# CC_MAX_POSITIONS=5                       # max concurrent open positions

# ─── cross-market-mm ────────────────────────────────────────────────
# Cross-venue market-making (Polymarket book → Limitless quotes → hedge).
# `npm run cross-market-mm`
#
# Easiest path: `npm run cross-market-mm:init` — a guided, re-runnable
# bootstrap that scaffolds these files, checks your credentials, deploys the
# Polymarket deposit wallet, and prints the exact addresses to fund.
#
# Auth model — three credentials, two purposes:
#   - Limitless trading: PRIVATE_KEY + the HMAC token (LMTS_TOKEN_ID +
#     LMTS_TOKEN_SECRET) set above. Legacy LIMITLESS_API_KEY also works.
#   - Polymarket trading: NO separate key — the bot derives CLOB credentials
#     from your PRIVATE_KEY signature at boot (authProbe in client.ts).
#   - Polymarket deposit-wallet SETUP (one time only): the relayer key above
#     (RELAYER_API_KEY + RELAYER_API_KEY_ADDRESS). `cross-market-mm:setup-poly`
#     needs it to derive + gaslessly deploy your deposit wallet. The running
#     bot does not.
#
# Funding — one EOA, but two chains and TWO different addresses:
#   - Base (chain 8453) → your EOA address: USDC (collateral) + a little ETH
#     (gas, for the one-time Limitless approvals).
#   - Polygon (chain 137) → your DEPOSIT-WALLET address (the one setup-poly
#     prints, NOT the address in Polymarket's UI, NOT your EOA): pUSD only.
#     The deposit-wallet flow is gasless via the relayer — no MATIC needed.
#     ⚠ pUSD anywhere but the deposit wallet is not CLOB buying power.
#
# YAML config lives in cross-market-mm.config.yaml — see
# src/strategies/cross-market-mm/config.example.yaml for the schema (this is
# where poly_funder, poly_signature_type, market_pairs, and trading params go).
# CROSS_MARKET_MM_CONFIG_PATH=./cross-market-mm.config.yaml

# ═════════════════════════════════════════════════════════════
# OPTIONAL — Telegram push notifier (cross-market-mm)
# ═════════════════════════════════════════════════════════════
# The bot always writes a live status file (data/cross-market-mm-status.json)
# that an orchestrating agent can read and relay — no creds needed for that.
# These two are ONLY for the optional direct-to-Telegram push (fill pings +
# heartbeat) when running standalone without an agent. Unset = disabled.
#   - TELEGRAM_BOT_TOKEN: from @BotFather (create a bot, copy the token)
#   - TELEGRAM_CHAT_ID:   your chat id (message @userinfobot, or read it from
#                         the getUpdates API after messaging your bot once)
# Verify with: npm run cross-market-mm:telegram-test
# TELEGRAM_BOT_TOKEN=123456789:ABCdef...
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_HEARTBEAT_MS=60000   # heartbeat cadence (default 60s); 0 disables
