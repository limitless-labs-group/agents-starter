# agents-starter env. Copy to .env, fill in, never commit it.
# cross-market-mm setup guide: src/strategies/cross-market-mm/SKILL.md

# ── Required ──

# Dedicated trading EOA, NOT your main wallet. Signs on Base + Polygon.
PRIVATE_KEY=0x...

# Limitless auth: scoped HMAC token.
# UI: connect wallet, API token modal, "API Tokens", Derive (or: npm run derive-token).
LMTS_TOKEN_ID=your-token-id
LMTS_TOKEN_SECRET=your-base64-secret

# Polymarket relayer key. Used ONCE by `cross-market-mm:setup-poly` to deploy your
# deposit wallet; the running bot derives its Poly creds from PRIVATE_KEY.
# Source: Polymarket builder dashboard. ADDRESS = your EOA's 0x address.
RELAYER_API_KEY=your-relayer-api-key
RELAYER_API_KEY_ADDRESS=0xyour-eoa-address

# Safety: true logs every order intent, signs and submits nothing.
# Keep true until you have watched a clean dry run.
DRY_RUN=true

# ── Optional ──

LOG_LEVEL=info   # trace | debug | info | warn | error | fatal

# cross-market-mm data + config paths. Set DATA_DIR ABSOLUTE so the Academy
# operator panel can point at the same dir.
# CROSS_MARKET_MM_DATA_DIR=/abs/path/to/agents-starter/data
# CROSS_MARKET_MM_CONFIG_PATH=./cross-market-mm.config.yaml

# Telegram push (optional). The bot always writes data/cross-market-mm-status.json
# for an agent to read, so these are only for direct phone pings.
# TELEGRAM_BOT_TOKEN=123456789:ABCdef...   # @BotFather
# TELEGRAM_CHAT_ID=123456789               # @userinfobot

# Legacy Limitless X-API-Key (only if you already hold one; new setups use the token above).
# LIMITLESS_API_KEY=

# Endpoint overrides. Defaults work; set only for staging/custom envs.
# LIMITLESS_API_URL / LIMITLESS_WS_URL
# POLYMARKET_CLOB_URL / POLYMARKET_GAMMA_URL / POLYMARKET_DATA_URL / POLYMARKET_WS_URL

# Other strategies (oracle-arb, certainty-closer) expose optional ORACLE_* / CC_*
# tunables with defaults. See each strategy's header in src/strategies/.
