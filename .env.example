# ═════════════════════════════════════════════════════════════
# REQUIRED — every strategy needs these
# ═════════════════════════════════════════════════════════════

# Wallet private key. Signs orders on Limitless (Base). For the replicator
# strategy, ALSO signs on Polymarket (Polygon) — same EOA, two chains.
# Use a dedicated trading wallet, never your main wallet.
PRIVATE_KEY=0x...your-wallet-private-key

# Limitless API key. Find it in your account settings at app.limitless.exchange.
# (Keys are random alphanumeric — no fixed prefix.)
# This codebase authenticates via the X-API-Key header. If you get
# "Invalid or revoked API key" on authed endpoints, your key may be for a
# different auth method (Limitless's API also supports HMAC, Identity, cookie).
# Confirm in the Limitless UI that the key you copied is the X-API-Key variant.
LIMITLESS_API_KEY=your-api-key

# ═════════════════════════════════════════════════════════════
# SAFETY — set DRY_RUN=true for your first runs
# ═════════════════════════════════════════════════════════════

# true: every order intent is logged, nothing is signed or submitted.
# false: real orders, real money.
DRY_RUN=true

# ═════════════════════════════════════════════════════════════
# GENERAL
# ═════════════════════════════════════════════════════════════

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Where strategies persist learning files + position state. Default: ./data
# DATA_DIR=./data

# CoinGecko free tier works without a key but rate-limits aggressively.
# Used by signal-sniper to read spot prices.
# COINGECKO_API_KEY=CG-...

# Dashboard HTTP port. Only used by `npm run dashboard`.
# DASHBOARD_PORT=3456

# ═════════════════════════════════════════════════════════════
# URL OVERRIDES — defaults work; override only for staging / custom envs
# ═════════════════════════════════════════════════════════════

# Limitless
# LIMITLESS_API_URL=https://api.limitless.exchange
# LIMITLESS_WS_URL=wss://ws.limitless.exchange

# Polymarket (replicator only)
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_DATA_URL=https://data-api.polymarket.com
# POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ═════════════════════════════════════════════════════════════
# PER-STRATEGY TUNABLES — all optional, defaults shown
# ═════════════════════════════════════════════════════════════

# ─── signal-sniper ─────────────────────────────────────────────
# Reacts to CoinGecko spot moves vs short-duration price markets.
# `npm run signal-sniper`
# SNIPER_EXPERIMENT=signal-sniper-v1               # id used in trade logs
# SNIPER_ASSETS=bitcoin,ethereum,solana,dogecoin   # CoinGecko ids (lowercase)
# SNIPER_BET_SIZE=0.50                             # USD per trade
# SNIPER_MIN_EDGE=10                               # min % edge to act (10 = 10%)

# ─── conviction-sniper ─────────────────────────────────────────
# Agrees with the market leader + Hermes/Pyth oracle conviction boost.
# `npm run conviction-sniper`
# WARNING: SNIPER_ASSETS uses Pyth TICKERS here (BTC/ETH/SOL), NOT the
# CoinGecko ids used by signal-sniper. SNIPER_BET_SIZE is shared.
# SNIPER_ASSETS=BTC,ETH,SOL                # Pyth tickers
# SNIPER_BET_SIZE=0.50                     # USD per trade
# SNIPER_MIN_LEAD=0.65                     # min market price on the leading side
# SNIPER_MAX_LEAD=0.93                     # max market price (skip near-certain)
# SNIPER_MIN_CONVICTION=3.0                # distance-from-strike / oracle-CI
# SNIPER_MIN_AGREEMENT=0.60                # oracle probability on same side
# SNIPER_MIN_MINUTES=3                     # min minutes to expiry
# SNIPER_MAX_MINUTES=25                    # max minutes to expiry
# SNIPER_MAX_POSITIONS=10                  # max concurrent open positions

# ─── oracle-arb ────────────────────────────────────────────────
# Hermes/Pyth oracle vs market price arbitrage.
# `npm run oracle-arb`
# ORACLE_ASSETS=BTC,ETH,SOL                # Pyth tickers
# ORACLE_MIN_CONFIDENCE=0.82               # min oracle confidence (0..1)
# ORACLE_MIN_EDGE=0.20                     # min edge oracle vs market (0..1)
# ORACLE_MIN_PRICE=0.30                    # market-price floor; skip below
# ORACLE_MAX_PRICE=0.65                    # market-price ceiling; skip above
# ORACLE_BET_SIZE=1                        # USD per trade
# ORACLE_MAX_POSITIONS=10                  # max concurrent open positions
# ORACLE_MIN_MINUTES=0                     # min minutes to expiry
# ORACLE_MAX_MINUTES=90                    # max minutes to expiry

# ─── cross-market-arb ──────────────────────────────────────────
# Buys YES + NO on the same Limitless market when prices sum to < $1.
# `npm run cross-market-arb`
# ARB_BET_SIZE=10                          # USD per arb leg
# ARB_MIN_SPREAD=3                         # min profit % to act (3 = 3%)
# ARB_SCAN_INTERVAL=30000                  # ms between scans

# ─── replicator ────────────────────────────────────────────────
# Cross-venue market-making (Polymarket book → Limitless quotes → hedge).
# `npm run replicator`
#
# Auth model:
#   - Limitless side: PRIVATE_KEY + LIMITLESS_API_KEY (set above).
#   - Polymarket side: NO separate API key needed. The bot derives CLOB
#     credentials from your PRIVATE_KEY signature at boot (see authProbe in
#     src/core/polymarket/client.ts). If you've ever created Polymarket API
#     keys before, the derivation returns your existing ones.
#
# Funding: Your PRIVATE_KEY is one EOA but funding lives on two chains.
#   - Limitless: USDC + ETH for gas on Base (chain 8453).
#   - Polymarket: USDC + MATIC for gas on Polygon (chain 137), sent to the
#     address Polymarket's UI shows you (depends on poly_signature_type —
#     2 = legacy Safe address, 3 = new deposit wallet address).
#
# YAML config lives in replicator.config.yaml — see
# src/strategies/replicator/config.example.yaml for the schema (this is
# where poly_funder, poly_signature_type, market_pairs, and trading params go).
# REPLICATOR_CONFIG_PATH=./replicator.config.yaml
