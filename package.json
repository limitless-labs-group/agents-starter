{
  "name": "agents-starter",
  "version": "1.0.0",
  "description": "Build autonomous trading agents for Limitless Exchange prediction markets on Base",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/index.ts",
    "oracle-arb": "npx tsx src/strategies/oracle-arb/run.ts",
    "certainty-closer": "tsx src/strategies/certainty-closer/run.ts",
    "redeem": "npx tsx src/core/limitless/redeem.ts",
    "cross-market-mm": "tsx src/strategies/cross-market-mm/run.ts",
    "cross-market-mm:find-pairs": "tsx src/strategies/cross-market-mm/find-pairs.ts",
    "cross-market-mm:setup-poly": "tsx src/strategies/cross-market-mm/setup-poly-wallet.ts",
    "cross-market-mm:preflight": "tsx src/strategies/cross-market-mm/preflight.ts",
    "cross-market-mm:flatten": "tsx src/strategies/cross-market-mm/flatten.ts",
    "cross-market-mm:close": "tsx src/strategies/cross-market-mm/close.ts",
    "cross-market-mm:status": "tsx src/strategies/cross-market-mm/status.ts",
    "cross-market-mm:analyze": "tsx src/strategies/cross-market-mm/analyze.ts",
    "derive-token": "tsx src/core/limitless/derive-token.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "prediction-markets",
    "trading-bot",
    "limitless",
    "base-chain",
    "defi"
  ],
  "author": "Limitless Labs",
  "license": "MIT",
  "dependencies": {
    "@limitless-exchange/sdk": "^1.0.9",
    "@polymarket/builder-relayer-client": "^0.0.10",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@types/node": "^22.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "eventsource": "^4.1.0",
    "js-yaml": "^4.1.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "viem": "^2.20.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "vitest": "^2.1.9"
  }
}
