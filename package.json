{
  "name": "agents-starter",
  "version": "1.0.0",
  "description": "Build autonomous trading agents for Limitless Exchange prediction markets on Base",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/index.ts",
    "demo": "npx tsx src/demo.ts",
    "dashboard": "npx tsx src/dashboard.ts",
    "signal-sniper": "npx tsx src/strategies/signal-sniper/run.ts",
    "oracle-arb": "npx tsx src/strategies/oracle-arb/run.ts",
    "iterate": "npx tsx src/strategies/iterate.ts",
    "iterate:analyze": "npx tsx src/strategies/iterate.ts analyze",
    "iterate:markets": "npx tsx src/strategies/iterate.ts markets",
    "redeem": "npx tsx src/core/limitless/redeem.ts",
    "conviction-sniper": "tsx src/strategies/conviction-sniper/run.ts",
    "replicator": "tsx src/strategies/replicator/run.ts",
    "replicator:find-pairs": "tsx src/strategies/replicator/find-pairs.ts",
    "replicator:analyze": "tsx src/strategies/replicator/analyze.ts",
    "derive-token": "tsx src/core/limitless/derive-token.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "prediction-markets",
    "trading-bot",
    "limitless",
    "base-chain",
    "defi"
  ],
  "author": "Limitless Labs",
  "license": "MIT",
  "dependencies": {
    "@limitless-exchange/sdk": "^1.0.9",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@types/node": "^22.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "eventsource": "^4.1.0",
    "js-yaml": "^4.1.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "viem": "^2.20.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "vitest": "^2.1.9"
  }
}
